{
  "name": "Firefox-mobile codespace",
  // Build from a Dockerfile based on the official Node.js devcontainer image.
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ]
    }
  },
  // Run a small post-create script to install dependencies if a package.json exists
  "postCreateCommand": "bash ./.devcontainer/post-create.sh || true",
  "remoteUser": "vscode"
}
